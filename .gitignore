# ============================================================
#  P08 — Déployez et monitorez votre modèle de scoring
#  .gitignore
# ============================================================

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ---- Couverture de tests (pytest-cov) ----
.coverage
.coverage.*
htmlcov/
coverage.xml

# ---- Environnements virtuels ----
venv/
.venv/
env/
ENV/

# ---- Secrets & configuration locale (NE JAMAIS COMMITER) ----
.env
.env.*
*.key
*.pem

# ---- Données (volumineuses + potentiellement sensibles) ----
# On ignore tout le contenu de data/ ...
data/*
*.csv
*.parquet
# ... SAUF l'échantillon de référence du monitoring (léger, données publiques)
!data/reference_sample.parquet

# ---- Artefacts MLflow du P06 (n'ont rien à faire dans ce dépôt) ----
mlflow.db
mlruns/

# ---- Modèle : on IGNORE tous les .pkl SAUF l'artefact de serving ----
# Le modèle de prod doit être versionné pour que le build Docker / la CI
# fonctionnent. On exclut donc explicitement l'artefact unique de la règle.
*.pkl
!model/model_credit_scoring.pkl

# ---- Artefact ONNX : optimisation ÉTUDIÉE PUIS REJETÉE (régression de
# précision des arbres en float32). Non utilisé en production, régénérable
# via optimization/export_onnx.py. Cf. optimization/RAPPORT_OPTIMISATION.md.
*.onnx

# ---- Logs locaux ----
*.log
logs/*.jsonl

# ---- Rapports de monitoring générés (Evidently) ----
monitoring/reports/

# ---- Système d'exploitation ----
Thumbs.db
desktop.ini
.DS_Store

# ---- IDE ----
.vscode/
.idea/

# ---- Archive et old scripts ----
archive/